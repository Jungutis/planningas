generator client {
  provider = "prisma-client-js"
}

// Lokaliai — SQLite (veikia iškart). Produkcijai pakeisti į postgresql + env DATABASE_URL.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
}

model PlanningOrder {
  id           String    @id @default(uuid())
  partNumber   String
  quantity     Int
  color        String    @default("#3b82f6")
  lineId       String?
  startTime    DateTime?
  closed       Boolean   @default(false)
  comments     Json      @default("[]")
  scrapPercent Float     @default(0)
  createdAt    DateTime  @default(now())
}

model LineConfig {
  id               String @id
  name             String
  cycleTimeSeconds Float
}
